{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "APISix API Gateway — BIS Platform request metrics, latency, error rates, and upstream health",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests (5m)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(increase(apisix_http_requests_total[5m]))",
          "legendFormat": "Requests"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate (5m)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(increase(apisix_http_requests_total{status=~\"5..\"}[5m])) / sum(increase(apisix_http_requests_total[5m])) * 100",
          "legendFormat": "Error %"
        }
      ],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "P99 Latency",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(apisix_http_latency_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 2000 }] } } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Connections",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "apisix_nginx_http_current_connections{state=\"active\"}",
          "legendFormat": "Active"
        }
      ],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Rate by Route",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum by (route) (rate(apisix_http_requests_total[1m]))",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latency Percentiles (P50 / P95 / P99)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(apisix_http_latency_bucket[5m])) by (le))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, sum(rate(apisix_http_latency_bucket[5m])) by (le))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, sum(rate(apisix_http_latency_bucket[5m])) by (le))", "legendFormat": "P99" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP Status Code Distribution",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "sum by (status) (rate(apisix_http_requests_total[1m]))", "legendFormat": "HTTP {{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Rate Limit Rejections",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "sum(rate(apisix_http_requests_total{status=\"429\"}[1m]))", "legendFormat": "Rejected (429)" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "fixedColor": "red", "mode": "fixed" } } }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Upstream Health Status",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 6 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "apisix_upstream_status", "legendFormat": "{{name}}", "instant": true }
      ],
      "transformations": [{ "id": "organize", "options": {} }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["apisix", "gateway", "bis"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "BIS — APISix Gateway",
  "uid": "bis-apisix-gateway",
  "version": 1
}
