{
  "__inputs": [
    {
      "name": "DS_INFLUXDB_K6",
      "label": "InfluxDB-k6",
      "description": "InfluxDB datasource for k6 load test results",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.4.2" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "k6 load test results for BIS Payment Rails — p50/p95/p99 latency, TPS, error rate, and batch queue depth.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "p50 Latency",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
          "query": "SELECT percentile(\"value\", 50) FROM \"http_req_duration\" WHERE $timeFilter AND \"name\" =~ /payment/ GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "p95 Latency",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
          "query": "SELECT percentile(\"value\", 95) FROM \"http_req_duration\" WHERE $timeFilter AND \"name\" =~ /payment/ GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "p99 Latency",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
          "query": "SELECT percentile(\"value\", 99) FROM \"http_req_duration\" WHERE $timeFilter AND \"name\" =~ /payment/ GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Error Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
          "query": "SELECT mean(\"value\") * 100 FROM \"http_req_failed\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Requests/sec",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
          "query": "SELECT mean(\"value\") FROM \"http_reqs\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Virtual Users",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
          "query": "SELECT last(\"value\") FROM \"vus\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Latency Trends",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ms"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "HTTP Request Duration — p50 / p95 / p99",
      "type": "timeseries",
      "targets": [
        {
          "alias": "p50",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
          "query": "SELECT percentile(\"value\", 50) AS \"p50\" FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "A"
        },
        {
          "alias": "p95",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
          "query": "SELECT percentile(\"value\", 95) AS \"p95\" FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "B"
        },
        {
          "alias": "p99",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
          "query": "SELECT percentile(\"value\", 99) AS \"p99\" FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Virtual Users Over Time",
      "type": "timeseries",
      "targets": [
        {
          "alias": "VUs",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
          "query": "SELECT last(\"value\") AS \"vus\" FROM \"vus\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Throughput & Errors",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 20,
      "title": "Requests per Second",
      "type": "timeseries",
      "targets": [
        {
          "alias": "RPS",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
          "query": "SELECT mean(\"value\") AS \"rps\" FROM \"http_reqs\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 21,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "targets": [
        {
          "alias": "Error %",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
          "query": "SELECT mean(\"value\") * 100 AS \"error_rate\" FROM \"http_req_failed\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "SLO Thresholds (1B Payments Lessons)",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          },
          "unit": "ms",
          "min": 0,
          "max": 1000
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 24 },
      "id": 30,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "title": "p95 vs SLO (< 200ms target)",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
          "query": "SELECT percentile(\"value\", 95) FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 10
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 24 },
      "id": 31,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "title": "Error Rate vs SLO (< 1% target)",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
          "query": "SELECT mean(\"value\") * 100 FROM \"http_req_failed\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "green", "value": 500 }
            ]
          },
          "unit": "reqps",
          "min": 0,
          "max": 2000
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 24 },
      "id": 32,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "title": "Throughput vs SLO (> 500 RPS target)",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_K6}" },
          "query": "SELECT mean(\"value\") FROM \"http_reqs\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["k6", "load-test", "payment-rails", "bis"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "UTC",
